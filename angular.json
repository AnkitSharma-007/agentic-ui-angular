{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "agentic-ui-angular": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/styles.scss"
            ],
            "allowedCommonJsDependencies": [
              "p-retry",
              "leaflet"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "650kB",
                  "maximumError": "850kB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "16kB",
                  "maximumError": "24kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "agentic-ui-angular:build:production"
            },
            "development": {
              "buildTarget": "agentic-ui-angular:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "coverageExclude": [
              "**/*.spec.ts",
              "**/*.types.ts",
              "**/*.descriptor.ts",
              "**/*.manifest.ts",
              "src/main.ts",
              "src/app/app.config.ts",
              "src/app/app.routes.ts",
              "src/app/core/registry/register-tools.ts",
              "src/app/shared/tools/itinerary-map/map-canvas.ts"
            ],
            "coverageReporters": [
              "text",
              "text-summary",
              "html",
              "lcov"
            ]
          }
        }
      }
    }
  }
}
